@model IEnumerable<CategoryNavViewModel>


<li class="mt-2">
    <a class="dropdown-item fw-bold bg-inherit" href="#">
        <div class="swap-light w-fit">
            Offers
        </div>
    </a>
</li>
<li class="mt-2">
    <a class="dropdown-item fw-bold bg-inherit" asp-area="" asp-controller="Products" asp-action="Index">
        <div class="swap-light w-fit">
            All Products
        </div>
    </a>
</li>

@foreach (var item in Model)
{   
    <li class="mt-2">
        <a class="dropdown-item fw-bold bg-inherit" asp-area="" asp-controller="Products" asp-action="Index" asp-route-categoryId="@item.Id" asp-route-categoryName="@item.Name">
            <div class="swap-light w-fit">
                @item.Name
            </div>
        </a>
    </li>
}
