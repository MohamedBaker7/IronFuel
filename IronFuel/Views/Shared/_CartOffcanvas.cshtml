<div class="offcanvas offcanvas-bottom border-0"
     tabindex="-1"
     id="successAddedOffcanvas"
     aria-labelledby="cartOffcanvasLabel">

    <div class="offcanvas-header pt-4 px-4 d-flex justify-content-center">
        <div class="success-badge py-3 w-100 d-flex justify-content-center mt-3">
            <span class="me-2">
                <svg role="presentation" focusable="false" stroke-width="2" width="18" height="18" class="offset-icon icon icon-success" style="--icon-height: 18px" viewBox="0 0 18 18">
                    <path d="M0 9C0 4.02944 4.02944 0 9 0C13.9706 0 18 4.02944 18 9C18 13.9706 13.9706 18 9 18C4.02944 18 0 13.9706 0 9Z" fill="currentColor"></path>
                    <path d="M5 8.8L7.62937 11.6L13 6" stroke="#ffffff" fill="none"></path>
                </svg>
            </span>
            Added to your cart!
        </div>
       
    </div>

    <div class="offcanvas-body px-4 py-3">
        <div class="d-flex gap-3 align-items-center">

            <div class="flex-shrink-0">
                <img id="cartOffcanvasImage"
                     src=""
                     alt=""
                     class="object-fit-cover"
                     style="width: 90px; height: 90px;" />
            </div>

            <div class="flex-grow-1">
                <p class="fw-bold text-uppercase mb-1 fs-6" id="cartOffcanvasName"></p>
                <p class="text-muted fw-semibold text-uppercase mb-1" id="cartOffcanvasPrice"></p>
                <p class="text-muted mb-1 small" id="cartOffcanvasSize_Flavour"></p>              
            </div>

        </div>
    </div>

    <div class="offcanvas-footer px-4 py-3 d-flex gap-2">
        <a asp-controller="Cart"
               asp-action="Index"
               class="btn btn-outline-dark rounded-0 py-2 fw-bold text-uppercase flex-fill">
            View Cart
        </a>
        <a asp-controller="Cart"
               asp-action="Checkout"
               class="btn btn-dark rounded-0 py-2 fw-bold text-uppercase flex-fill">
            Checkout
        </a>
    </div>

</div>
