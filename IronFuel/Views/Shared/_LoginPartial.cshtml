                <circle cx="11" cy="7" r="4" fill="none" stroke="currentColor"></circle>
                <path d="M3.5 19c1.421-2.974 4.247-5 7.5-5s6.079 2.026 7.5 5" fill="none" stroke="currentColor" stroke-linecap="round"></path>
