<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    @await RenderSectionAsync("Head", required: false)

    <title>@ViewData["Title"] | IronFuel</title>
    <script type="importmap"></script>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Outfit:wght@100..900&display=swap">

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/lib/select2/css/select2.min.css" />
    <link rel="stylesheet" href="~/lib/toastr.js/toastr.min.css" />
    <link rel="stylesheet" href="~/lib/animate.css/animate.min.css" />
    <link rel="stylesheet" href="~/lib/datatables/css/datatables.bootstrap4.min.css" />
    
    @await RenderSectionAsync("Styles", required: false)
    <link rel="stylesheet" href="~/css/product.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="fixed-top">
        @if (ViewData["HideNavbar"] == null || !(bool)ViewData["HideNavbar"]!)
        {
            <partial name="_NavBar"></partial>
            }
        </header>

        <div class="container-fluid d-flex justify-content-center pb-3 px-0">
            <main role="main" class="w-100">
                @RenderBody()
                <partial name="_Modal" />
            </main>
        </div>

       

        <partial name="_CartSummaryOffcanvas" />

        <partial name="_CartOffcanvas" />

            
        <script src="~/lib/jquery/dist/jquery.min.js"></script>
        <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
        <script src="~/lib/select2/js/select2.min.js"></script>
        <script src="~/lib/bootbox.js/bootbox.min.js"></script>
        <script src="~/lib/toastr.js/toastr.min.js"></script>
        <script src="~/lib/datatables/js/jquery.datatables.min.js"></script>
        <script src="~/lib/datatables/js/datatables.bootstrap4.min.js"></script>
        <script src="~/js/mobile-menu.js" asp-append-version="true"></script>
        <script src="~/js/site.js" asp-append-version="true"></script>
        @await RenderSectionAsync("Scripts", required: false)
    </body>
</html>
