@model ProductViewModel

@{
    ViewData["Title"] = Model.Name;
    ViewData["MetaDescription"] = Model.Description?.Length > 160
        ? Model.Description[..157] + "..."
        : Model.Description;

    var placeholder = Url.Content("~/Images/creatine-micronized.png");
    var gallery = Model.Images.Count > 0 ? Model.Images : null;

    // Single helper: resolve a relative image path to a root-relative URL
    string ImgUrl(string rel) => Url.Content("~/" + rel.TrimStart('/'));

    var mainSrc = gallery != null ? ImgUrl(gallery[0].RelativePath) : placeholder;

    string? videoSrc = "/videos/creatine-video.mp4";
    string videoMime = "video/mp4";
    if (!string.IsNullOrWhiteSpace(Model.VideoUrl))
    {
        var v = Model.VideoUrl!.Trim();
        if (v.StartsWith("http://", StringComparison.OrdinalIgnoreCase) || v.StartsWith("https://", StringComparison.OrdinalIgnoreCase))
        {
            videoSrc = v;
        }
        else
        {
            var pathForUrl = v.StartsWith("~/", StringComparison.Ordinal) ? v : "~/" + v.TrimStart('/');
            videoSrc = Url.Content(pathForUrl);
        }

        var ext = System.IO.Path.GetExtension(Model.VideoUrl).ToLowerInvariant();
        videoMime = ext == ".webm" ? "video/webm" : ext == ".ogg" ? "video/ogg" : "video/mp4";
    }
}

@section Head {
    <meta name="description" content="@ViewData["MetaDescription"]" />
    <meta property="og:title" content="@Model.Name – @Model.Brand!.Name" />
    <meta property="og:description" content="@ViewData["MetaDescription"]" />
    @if (gallery != null)
    {
        <meta property="og:image" content="@mainSrc" />
    }
}

<input id="ProductId" type="hidden" value="@Model.Id" />

<nav class="mt-3 ms-4" aria-label="Breadcrumb">
    <ol class="breadcrumb"
        itemscope itemtype="https://schema.org/BreadcrumbList">
        <li class="breadcrumb-item"
            itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
            <a class="text-decoration-none text-black fw-bold"
                   asp-controller="Home" asp-action="Index"
                   itemprop="item">
                <span itemprop="name">Home</span>
            </a>
            <meta itemprop="position" content="1" />
        </li>
        <li class="breadcrumb-item active fw-semibold"
            aria-current="page"
            itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
            <span itemprop="name">@Model.Name</span>
            <meta itemprop="position" content="2" />
        </li>
    </ol>
</nav>

<div class="product-detail-wrapper mt-5 ms-lg-1 d-lg-grid p-3 p-lg-0">

    <div class="product-left sticky-lg pt-3" style="flex: 1;">

        <section class="gallery-section order-1 order-lg-0"
                 aria-label="Product images">

            <div class="gallery-wrapper">

                <div class="thumbs-wrapper d-none d-lg-flex flex-column"
                     role="list"
                     aria-label="Product image thumbnails">
                    @if (gallery != null)
                    {
                        foreach (var img in gallery)
                        {
                            <div class="mb-2" role="listitem">
                                <img src="@ImgUrl(img.RelativePath)"
                                     class="thumb-img"
                                     alt="@(Model.Name + " thumbnail")"
                                     role="button"
                                     tabindex="0"
                                     loading="lazy"
                                     aria-label="View image: @(Model.Name)" />
                            </div>
                        }
                    }
                    else
                    {
                        <div class="mb-2" role="listitem">
                            <img src="@placeholder"
                                 class="thumb-img"
                                 alt="@Model.Name thumbnail"
                                 role="button"
                                 tabindex="0"
                                 loading="lazy" />
                        </div>
                    }
                    </div>

                
                <div class="main-image-wrapper">
                    <img id="mainProductImage"
                         src="@mainSrc"
                         class="img-fluid w-100"
                         alt="@Model.Name"
                         loading="eager" />
                </div>

                @if (gallery != null)
                {
                    <div class="dots-container rounded-5 text-center mt-2 d-lg-none"
                         role="tablist"
                         aria-label="Image navigation">
                        @for (int i = 0; i < gallery.Count; i++)
                        {
                            <button class="dot-btn btn p-0 border-0"
                                    role="tab"
                                    aria-selected="@(i == 0 ? "true" : "false")"
                                    aria-label="Show image @(i + 1)"
                                    data-src="@ImgUrl(gallery[i].RelativePath)"
                                    data-index="@i"
                                    tabindex="@(i == 0 ? "0" : "-1")">
                            </button>
                        }
                    </div>
                }
            </div>

            
        </section>

    </div>

    <div class="product-right" style="flex: 1;">

        <section class="product-info order-2 order-lg-0">
            <h2 class="fw-semibold mt-2 fs-4" itemprop="brand">@Model.Brand!.Name</h2>
            <h1 class="fw-bold mt-3" itemprop="name">@Model.Name</h1>
            <hr />
            <div class="product-description py-3" itemprop="description">
                <ul class="description-list">
                    @foreach (var line in Model.Description?.Split(new[] { "\\n" }, StringSplitOptions.RemoveEmptyEntries) ?? Array.Empty<string>())
                    {
                        <li class="mb-2">@line.Trim()</li>
                    }
                </ul>
            </div>
            <hr />
        </section>

        <section class="selectors-section order-3 order-lg-0"
                 aria-label="Product options">
            <div class="mb-3">
                <label class="mb-2 text-muted fw-semibold" for="Flavors">Flavour:</label>
                <select id="Flavors"
                        class="form-select form-select-solid rounded-0 p-3 ps-5 shadow-none text-uppercase js-select2"
                        asp-for="SelectedFlavour"
                        asp-items="Model.Flavors"
                        aria-label="Select flavour">
                </select>

                

            </div>
            <div class="mb-3">
                <label class="mb-2 text-muted fw-semibold" for="Sizes">Size:</label>
                <select id="Sizes"
                        class="form-select form-select-solid rounded-0 p-3 ps-5 shadow-none text-uppercase js-select2"
                        asp-for="SelectedSizes"
                        asp-items="Model.Sizes"
                        aria-label="Select size">
                </select>
            </div>

            <div class="mt-3" aria-live="polite" aria-atomic="true">
                <span id="Price"
                      class="text-uppercase fs-4 fw-bold"
                      aria-label="Product price"></span>

                <span id="SoldOutBadge"
                      class="badge sold-out-badge ms-2 p-2 border-0 rounded-0 fw-bold"
                      aria-live="polite">
                    Sold Out
                </span>


                <span id="ServingsPerContainer"
                      class="text-muted fs-6 d-block mt-1"
                      aria-label="Servings per container"></span>
            </div>
        </section>

        <partial name="_AddToCartForm" model="Model"></partial>

            <section class="accordion-section order-5 order-lg-0">
                @if (!string.IsNullOrWhiteSpace(Model.Benefits))
                {
                    <partial name="_CollapseSection" model="@(new CollapseSectionViewModel {TargetId = "Benefits", Label = "Benefits", Content = Model.Benefits})"></partial>
                    }

                    @if (!string.IsNullOrWhiteSpace(Model.SuggestedUse))
                    {
                        <partial name="_CollapseSection" model="@(new CollapseSectionViewModel {TargetId = "SuggestedUse", Label = "SuggestedUse", Content = Model.SuggestedUse})"></partial>
                        }
                    </section>
                </div>
        
            </div>



            <div class="offcanvas offcanvas-bottom m-2 rounded-2 h-auto mh-75"
                 tabindex="-1"
                 id="flavorOffcanvas">
                <div class="offcanvas-header border-bottom">
                    <h6 class="offcanvas-title text-uppercase fw-bold">
                        Flavours
                    </h6>
                    <button type="button"
                            class="btn-close shadow-none"
                            data-bs-dismiss="offcanvas">
                    </button>
                </div>
                <div class="offcanvas-body p-2">
                    @foreach (var flavor in Model.Flavors)
                    {
                        <button type="button"
                                class="btn text-muted rounded-0 text-uppercase w-100 px-4 py-3 mb-1 text-center border-0 shadow-none flavor-option"
                                data-value="@flavor.Value"
                                data-text="@flavor.Text"
                                data-bs-dismiss="offcanvas">
                            @flavor.Text
                        </button>
                    }
                </div>
            </div>
        
            <div class="offcanvas offcanvas-bottom m-2 rounded-2 h-auto mh-75"
                 tabindex="-1"
                 id="sizeOffcanvas">
                <div class="offcanvas-header border-bottom">
                    <h6 class="offcanvas-title text-uppercase fw-bold">
                        Sizes
                    </h6>
                    <button type="button"
                            class="btn-close shadow-none"
                            data-bs-dismiss="offcanvas">
                    </button>
                </div>
                <div class="offcanvas-body p-2">
                    @foreach (var size in Model.Sizes)
                    {
                        <button type="button"
                                class="btn text-muted rounded-0 text-uppercase w-100 px-4 py-3 mb-1 text-center border-0 shadow-none size-option"
                                data-value="@size.Value"
                                data-text="@size.Text"
                                data-bs-dismiss="offcanvas">
                            @size.Text
                        </button>
                    }
                </div>
            </div>

        

            @if (!string.IsNullOrWhiteSpace(videoSrc))
            {

                <div class="p-3 p-lg-0">
                    <div class="ratio ratio-16x9 mt-5 p-5">
                        <video controls preload="metadata" aria-label="Product video for @Model.Name">
                            <source src="@videoSrc" type="@videoMime" />
                            Your browser does not support the video tag.
                        </video>
                    </div>
                </div>

            }

            
            <script>
                window.ProductVariants = @Html.Raw(Json.Serialize(Model.Variants.Select(v => new
                {
                                    sku = v.SKU,
                                    flavour = v.Flavour,
                                    size = v.WeightG,
                                    price = v.Price,
                                    stock = v.Stock
                })))
            </script>
            @section Scripts {
                
                <script src="~/js/details.js" asp-append-version="true" defer></script>
            }
