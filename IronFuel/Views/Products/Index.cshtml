@model ProductsPageViewModel

@{
    var title = string.IsNullOrEmpty(Model.CategoryName) ? "All Products" : Model.CategoryName;
    ViewData["Title"] = title;
}

<nav class="mt-3 ms-4" aria-label="Breadcrumb">
    <ol class="breadcrumb"
        itemscope itemtype="https://schema.org/BreadcrumbList">
        <li class="breadcrumb-item"
            itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
            <a class="text-decoration-none text-black fw-bold"
                   asp-controller="Home" asp-action="Index"
                   itemprop="item">
                <span itemprop="name">Home</span>
            </a>
            <meta itemprop="position" content="1" />
        </li>
        <li class="breadcrumb-item active fw-semibold"
            aria-current="page"
            itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
            <span itemprop="name">@title</span>
            <meta itemprop="position" content="2" />
        </li>
    </ol>
</nav>

<div id="pageSpinner" class="d-none">
    <img src="~/assets/images/navbarlogo.png" class="spinner-logo" alt="IronFuel" />
    <div class="spinner-ring"></div>
</div>


@if (Model.Products.Count() > 0)
{
    <div class="d-flex justify-content-center">
        <div class="row container-fluid px-0 mt-5">
            <div>
                <button class="btn btn-dark text-uppercase fw-semibold rounded-0 px-3 py-4 d-lg-none shadow-none filter-btn"
                        data-bs-toggle="offcanvas" data-bs-target="#mobileFilter">
                    <span class="me-2">
                        <svg role="presentation" fill="none" focusable="false" stroke-width="2" width="20" height="14" class="icon-subdued icon icon-filter" viewBox="0 0 20 14">
                            <path d="M1 2C0.447715 2 0 2.44772 0 3C0 3.55228 0.447715 4 1 4V2ZM1 4H5V2H1V4Z" fill="currentColor"></path>
                            <path d="M1 10C0.447715 10 0 10.4477 0 11C0 11.5523 0.447715 12 1 12V10ZM1 12H11V10H1V12Z" fill="currentColor"></path>
                            <path d="M10 2H9V4H10V2ZM19 4C19.5523 4 20 3.55228 20 3C20 2.44772 19.5523 2 19 2V4ZM10 4H19V2H10V4Z" fill="currentColor"></path>
                            <path d="M16 10H15V12H16V10ZM19 12C19.5523 12 20 11.5523 20 11C20 10.4477 19.5523 10 19 10V12ZM16 12H19V10H16V12Z" fill="currentColor"></path>
                            <circle cx="7" cy="3" r="2" stroke="currentColor"></circle>
                            <circle cx="13" cy="11" r="2" stroke="currentColor"></circle>
                        </svg>
                    </span>
                    Filter and sort
                </button>

                <div class="offcanvas offcanvas-end h-auto m-3" tabindex="-1" id="mobileFilter">
                    <div class="offcanvas-header">
                        <h4 class="fw-bold">Filters</h4>
                        <button type="button" class="btn-close shadow-none" data-bs-dismiss="offcanvas"></button>
                    </div>
                    <div class="offcanvas-body fw-bold">
                        <partial name="_Filters" model="Model" />
                    </div>
                </div>
            </div>

            <div class="col-3 pe-5 ps-0 fs-5 fw-bold filters-sidebar">
                <div class="fw-semibold">
                    <svg role="presentation" fill="none" focusable="false" stroke-width="2" width="20" height="14" class="icon-subdued icon icon-filter" viewBox="0 0 20 14">
                        <path d="M1 2C0.447715 2 0 2.44772 0 3C0 3.55228 0.447715 4 1 4V2ZM1 4H5V2H1V4Z" fill="currentColor"></path>
                        <path d="M1 10C0.447715 10 0 10.4477 0 11C0 11.5523 0.447715 12 1 12V10ZM1 12H11V10H1V12Z" fill="currentColor"></path>
                        <path d="M10 2H9V4H10V2ZM19 4C19.5523 4 20 3.55228 20 3C20 2.44772 19.5523 2 19 2V4ZM10 4H19V2H10V4Z" fill="currentColor"></path>
                        <path d="M16 10H15V12H16V10ZM19 12C19.5523 12 20 11.5523 20 11C20 10.4477 19.5523 10 19 10V12ZM16 12H19V10H16V12Z" fill="currentColor"></path>
                        <circle cx="7" cy="3" r="2" stroke="currentColor"></circle>
                        <circle cx="13" cy="11" r="2" stroke="currentColor"></circle>
                    </svg>
                    <span class="ms-2 fs-6 fw-lighter">Filters</span>
                    <hr class="mt-0">
                </div>
                <partial name="_Filters" model="Model"></partial>
                </div>

                <div class="p-lg-0 col-lg-9">
                    <partial name="_ProductsList" model="Model"></partial>
                    </div>
                </div>

            </div>
        }
        else
        {
            <div class="text-center mt-5">
                <h3>Nothing Here Yet</h3>
                <p class="text-muted fs-5">
                    Looks like this category is still warming up.
                    Explore other supplements and fuel your workout!
                </p>
            </div>
        }



        @section Scripts {
            <script src="~/js/products.js" asp-append-version="true"></script>
        }
