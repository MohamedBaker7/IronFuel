@model IronFuel.Web.Core.ViewModels.ProductViewModel

<section class="purchase-section order-4 order-lg-0 mt-3"
         aria-label="Purchase options">

    <form id="AddToCartForm" novalidate>

        <input type="hidden" name="sku" id="SKU" />

        <label class="mb-2 text-muted fw-semibold" for="QuantityInput">
            Quantity:
        </label>

        <div class="d-flex justify-content-center border border-muted border-1 quantity-control-wrapper"
             role="group"
             aria-label="Quantity selector">
            <div class="d-flex p-2 w-100 justify-content-between">

                <button id="QuantityDecrease"
                        type="button"
                        class="btn border-0 rounded-0 quantity-arrow-btn"
                        aria-label="Decrease quantity"
                        aria-controls="QuantityInput">
                    <svg viewBox="0 0 16 16" width="16" height="16"
                         fill="none" stroke="currentColor" stroke-width="2"
                         stroke-linecap="round" aria-hidden="true" focusable="false">
                        <line x1="3" y1="8" x2="13" y2="8" />
                    </svg>
                </button>

                <input id="QuantityInput"
                       type="number"
                       name="qty"
                       class="form-control border-0 rounded-0 text-center quantity-input"
                       min="1"
                       max="10"
                       value="1"
                       aria-label="Quantity"
                       aria-describedby="QuantityDecrease QuantityIncrease" />

                <button id="QuantityIncrease"
                        type="button"
                        class="btn border-0 rounded-0 quantity-arrow-btn"
                        aria-label="Increase quantity"
                        aria-controls="QuantityInput">
                    <svg viewBox="0 0 16 16" width="16" height="16"
                         fill="none" stroke="currentColor" stroke-width="2"
                         stroke-linecap="round" aria-hidden="true" focusable="false">
                        <line x1="8" y1="3" x2="8" y2="13" />
                        <line x1="3" y1="8" x2="13" y2="8" />
                    </svg>
                </button>

            </div>
        </div>

        <button id="AddToCartBtn"
                type="submit"
                class="btn btn-dark rounded-0 py-3 fw-bold text-uppercase add-to-cart-btn w-100 mt-3"
                aria-label="Add @Model.Name to cart">
            Add to Cart
        </button>

    </form>

</section>


@Html.AntiForgeryToken()

