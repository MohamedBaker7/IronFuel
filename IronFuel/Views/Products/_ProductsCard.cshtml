@model IEnumerable<ProductViewModel>

<input type="hidden" id="product-count-hidden" value="@Model.Count()" />
@foreach (var product in Model)
{
    <div class="card col mt-4 rounded-0 border-0 product-card">
        <div class="card-body pb-4 fw-semibold fs-5">
            <a class="product-link mb-3 d-block" asp-action="Details" asp-route-id="@product.Id" style="background-image: url('/Images/gold-standard-100-whey-protein.png');">
            </a>
            <div class="fs-5 fw-bold">@product.Name</div>
            <div class="mb-2 fs-6 text-muted">Rating</div>
            <div class="mb-2 fs-6 text-muted">1245 Reviews</div>
            <div class="mb-2">@(product.LowestPrice == 0 ? string.Empty : $"{product.LowestPrice} EGP") </div>

        </div>
        <div class="card-footer d-flex justify-content-center bg-black rounded-0">
            <a class="btn fw-bold py-2 text-white text-decoration-none w-100 quick-add-btn">
                + QUICK ADD
                </a>
        </div>
    </div>
}
