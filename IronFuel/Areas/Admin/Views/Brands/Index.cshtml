@model IReadOnlyList<BrandViewModel>
@{
    var title = "Manage brands";
    ViewData["Title"] = title;
}

<nav class="mt-3 ms-4" aria-label="Breadcrumb">
    <ol class="breadcrumb"
        itemscope itemtype="https://schema.org/BreadcrumbList">
        <li class="breadcrumb-item"
            itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
            <a class="text-decoration-none text-black fw-bold"
                   asp-area="" asp-controller="Home" asp-action="Index"
                   itemprop="item">
                <span itemprop="name">Home</span>
            </a>
            <meta itemprop="position" content="1" />
        </li>
        <li class="breadcrumb-item active fw-semibold"
            aria-current="page"
            itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
            <span itemprop="name">@title</span>
            <meta itemprop="position" content="2" />
        </li>
    </ol>
</nav>

<div class="mt-5 pt-3 ms-4 me-4 mb-5">
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-4">
        <h1 class="h3 mb-0">Manage brands</h1>
        <a href="javascript:;" class="btn btn-dark rounded-0 js-render-modal" data-title="Add Brand" data-url="@Url.Action("Create", "Brands", new { area = "Admin" })">Add Brand</a>
    </div>
</div>

@if (TempData["StatusMessage"] is string status)
{
    <div class="alert alert-success rounded-0" role="alert">@status</div>
}

@if (Model.Count == 0)
{
    <p class="text-muted">No brands yet. Create one to get started.</p>
}
else
{
    <div class="card rounded-0 border-0">
        <div class="card-body">
            <div class="table-responsive">
                <table id="Brands" class="table table-striped table-hover align-middle w-100 js-datatables" data-document-title="Brands">
                    <thead>
                        <tr class="fw-bold fs-5 text-gray-800">
                            <th>Name</th>
                            <th>Status</th>
                            <th>Created On</th>
                            <th>LastUpdated On</th>
                            <th class="text-end">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var brand in Model)
                        {
                            <partial name="_BrandRow" model="brand" />
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
@Html.AntiForgeryToken()

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
