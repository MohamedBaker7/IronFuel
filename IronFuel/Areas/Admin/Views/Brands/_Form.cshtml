@model BrandFormViewModel

<form class="js-form" asp-action="@(Model?.Id > 0 ? "Edit" : "Create")"
      data-ajax-method="post"
      data-ajax="true"
      data-ajax-begin="onModelBegin"
      data-ajax-success="onModalSuccess"
      data-ajax-failure="showErrorMessage"
      data-ajax-complete="onModelComplete">
    <div>

        <div class="form-floating mb-2">
            @if (Model?.Id > 0)
            {
                <input type="hidden" asp-for="Id" />
            }
            <input type="text" class="form-control form-control-solid rounded-0 border-black" placeholder="" asp-for="Name" autocomplete="off" />
            <label asp-for="Name"></label>
            <span asp-validation-for="Name" class="text-danger d-block"></span>
        </div>
            
        <div class="form-floating mb-2">
            <input type="text" class="form-control form-control-solid rounded-0 border-black" asp-for="Code" placeholder="" autocomplete="off" />
            <label asp-for="Code"></label>
            <span asp-validation-for="Code" class="text-danger d-block"></span>        
        </div>
      
    </div>
</form>
